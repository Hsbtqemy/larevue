# ============================================================
# Variables d'environnement — copier vers .env et compléter
# Ne jamais commiter .env dans git
# ============================================================

# Django
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=editorial_tool
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Fichiers statiques et médias
STATIC_URL=/static/
MEDIA_URL=/media/

# Email (laisser vide en développement — console backend utilisé)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=contact@example.com
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@example.com

# Sentry (production uniquement — décommenter si besoin)
# SENTRY_DSN=https://xxxx@sentry.io/yyyy
